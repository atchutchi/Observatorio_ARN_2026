# Django
DJANGO_SECRET_KEY=your-secret-key-here-generate-with-django-get-random-secret-key
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,backend

# PostgreSQL
POSTGRES_DB=observatorio_telecom
POSTGRES_USER=observatorio
POSTGRES_PASSWORD=your-db-password-here
POSTGRES_HOST=db
POSTGRES_PORT=5432

# Redis
REDIS_URL=redis://redis:6379/0

# Celery
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# Google Gemini (Phase 5)
GEMINI_API_KEY=

# Reference data
POPULATION_REFERENCE=2070000

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
NEXT_PUBLIC_APP_NAME=Observatório Telecom GB

# Admin superuser (created on first run)
DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_EMAIL=admin@arn.gw
DJANGO_SUPERUSER_PASSWORD=change-this-password
